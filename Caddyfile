:80 {
    encode gzip

    handle /healthz {
        reverse_proxy api-service:8080
    }

    handle /v1/* {
        reverse_proxy api-service:8080
    }

    handle /proto/* {
        reverse_proxy protocol-gateway:8081
    }

    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
