# Copy to .env and fill in before running docker compose up.
# Never commit .env to version control.

# Postgres password (used in DATABASE_URL inside the container network)
DB_PASSWORD=change_me_strong_password

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret

# The public hostname Caddy will obtain a TLS cert for.
# Set to "localhost" for local dev (Caddy uses a self-signed cert).
DOMAIN=your.domain.example.com
